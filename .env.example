# AI Development Standards MCP Server Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# GitHub Configuration (for standards loading)
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=nickagillis
GITHUB_REPO=ai-development-standards

# Standards Configuration
STANDARDS_CACHE_TTL=3600
STANDARDS_AUTO_UPDATE=true
STANDARDS_VALIDATION_STRICT=false

# MCP Configuration
MCP_SERVER_NAME=ai-development-standards
MCP_SERVER_VERSION=1.0.0
MCP_MAX_CONCURRENT_SESSIONS=10

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Security Configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
API_KEY_REQUIRED=false

# Future: Community Wisdom Engine Integration
CWE_ENABLED=false
CWE_ENDPOINT=https://api.community-wisdom.example.com
CWE_API_KEY=your_cwe_api_key_here
